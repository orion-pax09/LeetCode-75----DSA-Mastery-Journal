#include <iostream>
using namespace std;
class Solution {
public:
    string mergeAlternately(string word1,string word2) {
        string merged_String = "";
        int i = 0 ;
        int j =0 ;
        while (i < word1.size()&&j<word2.size()){
            merged_String +=word1[i++];
            merged_String+=word2[j++];
        }
        
        while (i < word1.size()){
            merged_String +=word1[i++];
        }
        while (j < word2.size()){
            merged_String += word2[j++];
        }
        return merged_String;
    }
};
