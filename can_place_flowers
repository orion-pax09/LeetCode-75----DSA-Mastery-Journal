#include <iostream>
#include <vector>
using namespace std;
class Solution {
public:
    bool canPlaceFlowers(vector<int>& flowerbed, int n) {
        if (flowerbed.size()<1){
            cout << "Size of array should not be less than one"<<endl;
        }
        if (flowerbed.size() > 10000){
            cout << "Size of array should not exceed 10000"<<endl;
        }
        if ( n < 0){
            cout << "n can't be less than zero"<<endl;
        }
        if (n > flowerbed.size()){
            cout << "n can't be greater than size of array"<<endl;
        }
        int count = 0;
        for (int i = 0 ; i < flowerbed.size() ; i++){
            if (flowerbed[i] == 0 && (i == 0 || flowerbed[i-1] == 0)&&(i == flowerbed.size()-1 || flowerbed[i+1]==0)){
                flowerbed[i] = 1;
                count++;
            }
        }
        if (count>=n){
            return true;
        }
        return false;
    }
};
int main(){
    vector<int >flowerbed = {0,0,1};
    Solution s;
    cout << s.canPlaceFlowers(flowerbed , 1);
}
/*
Constraints:

1 <= flowerbed.length <= 2 * 104
flowerbed[i] is 0 or 1.
There are no two adjacent flowers in flowerbed.
0 <= n <= flowerbed.length
{1,0,0,0,1}, n = 1   // true
{1,0,0,0,1}, n = 2   // false
{0}, n = 1           // true
{1}, n = 0           // true
{0,0,0}, n = 2       // true
{0,0,1}, n = 1       // true
*/
